generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model travel_blog {
  blog_id    Int    @id @default(autoincrement())
  place_name String @db.VarChar(45)
  review     String @db.VarChar(200)
  user_id    Int?
  pictures   String @db.VarChar(500)
  cost       Int
  users      users? @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "user_id")

  @@index([user_id], map: "user_id_idx")
  @@map("travel-blog")
}

model users {
  user_id     Int           @id @default(autoincrement())
  first_name  String        @db.VarChar(45)
  last_name   String        @db.VarChar(45)
  email       String        @unique(map: "email_UNIQUE") @db.VarChar(100)
  password    String        @db.VarChar(200)
  profile_pic String?       @db.VarChar(200)
  travel_blog travel_blog[]
}

model booking {
  booking_id          Int             @id @default(autoincrement())
  order_id            String          @db.VarChar(200)
  amount              Float
  currency            String          @db.VarChar(200)
  receipt             String?         @db.VarChar(200)
  status              booking_status?
  razorpay_payment_id String?         @db.VarChar(200)
  razorpay_signature  String?         @db.VarChar(200)
  details             String?         @db.VarChar(200)
  blog_id             Int?
  user_id             Int?
}

enum booking_status {
  created
  attempted
  paid
}
